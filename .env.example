# ================================
# ENVIRONMENT VARIABLES - PRODUCTION
# ================================
# Copier ce fichier vers .env et remplir avec les vraies valeurs

# Database PostgreSQL
POSTGRES_USER=dpe_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=dpe_matching

# JWT Configuration (générer avec: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=7d

# CORS Configuration (URL du frontend en production)
CORS_ORIGIN=https://votre-domaine.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# External APIs
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE

# Monday.com Integration
MONDAY_API_KEY=YOUR_MONDAY_API_KEY
MONDAY_BOARD_ID=YOUR_MONDAY_BOARD_ID

# Email Configuration (optionnel)
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Frontend (optionnel - pour build avec API URL custom)
VITE_API_URL=http://localhost:3001
