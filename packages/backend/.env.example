# Environment
NODE_ENV=development

# Server
PORT=3001
HOST=localhost

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dpe_matching

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# External APIs
RAPIDAPI_KEY=your-rapidapi-key-here

# Matching Algorithm
DEFAULT_MAX_CANDIDATS=10
DEFAULT_SEUIL_SCORE_MINIMUM=30
DEFAULT_DISTANCE_MAX_GPS=500

# Email Configuration
# Option 1: Gmail SMTP (direct)
# Pour obtenir un mot de passe d'application Gmail:
# 1. Allez sur https://myaccount.google.com/security
# 2. Activez la validation en 2 étapes si ce n'est pas déjà fait
# 3. Allez dans "Mots de passe des applications" (https://myaccount.google.com/apppasswords)
# 4. Créez un nouveau mot de passe d'application pour "Autre (nom personnalisé)"
# 5. Copiez le mot de passe généré (16 caractères) dans EMAIL_PASSWORD
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Option 2: N8n Webhook (recommandé)
# URL du webhook N8n qui gérera l'envoi des emails
# Exemple: https://votre-instance-n8n.com/webhook/send-email
# Si configuré, cette option sera prioritaire sur Gmail SMTP
N8N_WEBHOOK_URL=
