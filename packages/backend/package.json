{
  "name": "@dpe-matching/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for DPE-Leboncoin matching system",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outdir=dist --packages=external --format=cjs --sourcemap && esbuild src/vercel-entry.ts --bundle --platform=node --outfile=api/index.js --packages=external --format=cjs",
    "build:tsc": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "download:dpe": "tsx scripts/download-dpe-ademe.ts",
    "import:dpe": "tsx scripts/import-dpe.ts",
    "import:leboncoin": "tsx scripts/import-leboncoin.ts",
    "fetch:dpe:pau": "tsx scripts/fetch-dpe-pau-v2.ts",
    "fetch:leboncoin:pau": "tsx scripts/fetch-leboncoin-pau.ts",
    "fetch:dvf:pau": "tsx scripts/fetch-dvf-pau.ts",
    "generate:dvf:demo": "tsx scripts/generate-dvf-demo.ts",
    "test:leboncoin": "tsx scripts/test-api-leboncoin.ts",
    "test:matching": "tsx scripts/test-matching.ts",
    "auto:sync": "tsx scripts/auto-sync.ts",
    "create:clusters": "tsx scripts/create-clusters.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@dpe-matching/shared": "workspace:*",
    "@prisma/client": "5.22.0",
    "@types/csv-parse": "^1.2.5",
    "bcryptjs": "^3.0.3",
    "cli-progress": "^3.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.9",
    "papaparse": "^5.5.3",
    "proj4": "^2.19.10",
    "puppeteer": "^24.24.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cli-progress": "^3.11.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.2",
    "@types/papaparse": "^5.3.16",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.25.10",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
