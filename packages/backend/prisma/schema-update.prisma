// Ajout à faire au schema.prisma existant

/// Clé API pour authentification programmatique
model ApiKey {
  id          String    @id @default(uuid())
  key         String    @unique @db.VarChar(64)
  name        String
  description String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json      // Array de permissions: ["dpe:read", "dpe:write", "matching:run"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([userId])
  @@map("api_keys")
}

// Modifier le model User pour ajouter la relation
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys   ApiKey[] // Nouvelle relation

  @@index([email])
  @@map("users")
}
