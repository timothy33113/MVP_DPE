{
  "version": 2,
  "installCommand": "npm install --no-package-lock @prisma/client@5.22.0 prisma@5.22.0",
  "buildCommand": "npx prisma generate",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}
