{
  "version": 2,
  "installCommand": "echo '{\"dependencies\":{\"@prisma/client\":\"5.22.0\",\"prisma\":\"5.22.0\"}}' > package.json && npm install --no-package-lock",
  "buildCommand": "npx prisma generate",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}
