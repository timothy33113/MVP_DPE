{
  "buildCommand": "pnpm --filter @dpe-matching/shared build && cd packages/frontend && npx vite build",
  "outputDirectory": "packages/frontend/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
